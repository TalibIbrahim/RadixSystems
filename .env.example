# Example Configuration for Email Sending
# Copy this file to .env.local and fill in your actual SMTP credentials

# The hostname of your SMTP server (e.g., smtp.gmail.com, smtp.mailgun.org, smtp.office365.com)
SMTP_HOST=smtp.example.com

# The port of your SMTP server (usually 587 for TLS or 465 for SSL)
SMTP_PORT=587

# Your email address or SMTP username
SMTP_USER=you@example.com

# Your email password or App Password (if using Gmail, generate an App Password)
SMTP_PASS=your_secure_password
